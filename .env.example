# Universal Search — root environment template
# Copy to .env and fill in secrets before running make compose-up
# API keys may remain blank; services that require them are not exercised in make dev

# Qdrant vector database
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Meilisearch
MEILI_PORT=7700
MEILI_MASTER_KEY=dev_meili_master_key
MEILI_ENV=development

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=usearch
POSTGRES_PASSWORD=dev_pg_password
POSTGRES_DB=usearch

# Redis
REDIS_PORT=6379

# SearXNG
SEARXNG_PORT=8080
SEARXNG_BASE_URL=http://localhost:8080/
SEARXNG_SECRET=dev_searxng_secret

# LiteLLM proxy
LITELLM_PORT=4000
LITELLM_MASTER_KEY=dev_litellm_master_key

# LLM provider API keys (leave blank for local-only dev)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
