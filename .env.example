# Universal Search — root environment template
# Copy to .env: cp .env.example .env
# Fill in values before running make compose-up.
# This file is committed; .env is gitignored.
#
# Every ${VAR} referenced in deploy/docker-compose.yml must appear here.

# ── Meilisearch ────────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=change_me_meilisearch_key
MEILI_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=usearch
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=usearch
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=change_me_litellm_key
# Full DSN used by LiteLLM for its own database storage
DATABASE_URL=postgresql://usearch:change_me_postgres_password@postgres:5432/usearch
# Redis DSN used by LiteLLM for caching
REDIS_URL=redis://redis:6379/0

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ── SearXNG ────────────────────────────────────────────────────────────────────
SEARXNG_PORT=8080
SEARXNG_BASE_URL=http://localhost:8080/
SEARXNG_SECRET=change_me_searxng_secret

# ── LiteLLM provider API keys (optional; blank means provider disabled) ────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── LiteLLM budget cap per request (USD; 0 = unlimited) ───────────────────────
# SPEC-LLM-001 NFR-LLM-003: enforced post-flight by both proxy and client.
LITELLM_BUDGET_USD=0.50

# ── Ollama local inference base URL ───────────────────────────────────────────
# Leave default for Docker Desktop (macOS/Windows). Linux: http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── LiteLLM proxy port ─────────────────────────────────────────────────────────
LITELLM_PORT=4000

# ── Observability (REQ-OBS-001..REQ-OBS-005) ───────────────────────────────────
# Structured log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=info

# usearch admin server port for /metrics and /healthz (localhost-only)
# Leave blank to disable the admin server.
USEARCH_ADMIN_PORT=9090

# OpenTelemetry OTLP gRPC exporter endpoint (e.g. "localhost:4317").
# Leave blank to install a no-op tracer (zero overhead).
OTLP_ENDPOINT=

# Trace sampling ratio [0.0, 1.0]. Default 0.1 (10%).
OTLP_SAMPLE_RATIO=0.1

# Loki push endpoint (REQ-OBS-007, Phase 2 — reserved, not yet active).
LOKI_ENDPOINT=

# Prometheus UI port exposed by the prometheus container in docker-compose.
PROMETHEUS_PORT=9091

# Prometheus scrape port — must match USEARCH_ADMIN_PORT so Prometheus can
# reach the usearch /metrics endpoint from inside Docker.
PROMETHEUS_SCRAPE_PORT=9090

# ── Researcher synthesis sidecar (SPEC-SYN-001) ────────────────────────────────
# Base URL for the Go-side synthesis client to reach the sidecar.
RESEARCHER_BASE_URL=http://localhost:8081
# Per-request timeout in seconds for the Go-side synthesis HTTP client (default 10).
RESEARCHER_REQUEST_TIMEOUT_SECONDS=10
# Port the Python sidecar listens on inside Docker.
RESEARCHER_PORT=8081
# Default LLM model alias used by the sidecar (must be declared in deploy/litellm/config.yaml).
RESEARCHER_MODEL_DEFAULT=claude-haiku-4-5
# Synthesis wall-clock timeout in seconds for the Python sidecar LLM call.
RESEARCHER_TIMEOUT_SECONDS=8

# ── BGE-M3 embedding sidecar (SPEC-IDX-002) ────────────────────────────────────
# Base URL for the Go-side embedder client to reach the sidecar.
EMBEDDER_BASE_URL=http://localhost:8082
# Per-request timeout in seconds for the Go-side embedder HTTP client (default 15).
EMBEDDER_REQUEST_TIMEOUT_SECONDS=15
# Port the Python sidecar listens on inside Docker.
EMBEDDER_PORT=8082
# HuggingFace model ID for the embedding sidecar (default BAAI/bge-m3).
EMBEDDER_MODEL_NAME=BAAI/bge-m3
# Inference device: cpu | cuda (default cpu; override in docker-compose.gpu.yml).
EMBEDDER_DEVICE=cpu
# Use FP16 precision for GPU inference (default false; set true with EMBEDDER_DEVICE=cuda).
EMBEDDER_USE_FP16=false
# In-process LRU cache size in entries. Set 0 to disable the cache.
EMBEDDER_CACHE_MAX_ENTRIES=1024
# Log level for the Python sidecar: DEBUG | INFO | WARNING | ERROR (default INFO).
EMBEDDER_LOG_LEVEL=INFO

# ── Korean Tokenizer Sidecar (SPEC-IDX-003) ───────────────────────────────────
# mecab-ko FastAPI sidecar for Korean morphological tokenization.
# Runs alongside the main Go service; Go client falls back to Meili Lindera on 503.

# Base URL of the tokenizer sidecar. Used by the Go tokenizer.Client.
TOKENIZER_KO_BASE_URL=http://localhost:8083
# Per-request timeout in milliseconds (including retries).
TOKENIZER_KO_TIMEOUT_MS=500
# Maximum retry count for transient sidecar failures (5xx, network error).
TOKENIZER_KO_MAX_RETRIES=2
# Port the sidecar listens on.
TOKENIZER_KO_PORT=8083
# Log level for the Python sidecar: DEBUG | INFO | WARNING | ERROR (default INFO).
TOKENIZER_KO_LOG_LEVEL=INFO

# ── YouTube Extraction Sidecar (SPEC-ADP-005a) ───────────────────────────────
# yt-dlp FastAPI sidecar for YouTube video search. Runs as subprocess (GPL
# process-isolation). Port 8084 (no collision with embedder 8082 or tokenizer 8083).

# Base URL for the Go-side YouTube client to reach the sidecar.
YOUTUBE_BASE_URL=http://localhost:8084
# Port the Python sidecar listens on inside Docker.
YOUTUBE_PORT=8084
# Optional: path to yt-dlp cookies file for IP-block mitigation (leave blank for public path).
YT_COOKIES_PATH=
# Rate-limiting sleep flags passed to yt-dlp (defaults per ADP-005 D4).
YT_SLEEP_REQUESTS=1.0
YT_SLEEP_INTERVAL=2
YT_MAX_SLEEP_INTERVAL=5

# ── Deep Agent Pipeline (SPEC-DEEP-002) ────────────────────────────────────
# Multi-agent /deep pipeline: Researcher → Reviewer → Writer → Verifier.
# Each agent uses a LiteLLM model alias resolved at runtime.

# LiteLLM model alias for the Researcher agent (extracts claims from documents).
DEEP_AGENT_RESEARCHER_MODEL=claude-3-5-haiku-20241022
# LiteLLM model alias for the Reviewer agent (critiques extracted claims).
DEEP_AGENT_REVIEWER_MODEL=claude-3-5-haiku-20241022
# LiteLLM model alias for the Writer agent (drafts the long-form report).
DEEP_AGENT_WRITER_MODEL=claude-3-5-sonnet-20241022
# LiteLLM model alias for the Verifier agent (faithfulness check).
DEEP_AGENT_VERIFIER_MODEL=claude-3-5-sonnet-20241022
# Maximum Writer retries on Verifier rejection (total attempts = retries + 1).
DEEP_AGENT_MAX_RETRIES=2
# Backoff delay in milliseconds between Writer retry attempts.
DEEP_AGENT_WRITER_RETRY_DELAY_MS=500
# Timeout in milliseconds for the faithfulness check HTTP call.
DEEP_AGENT_VERIFIER_TIMEOUT_MS=30000
# URL for the researcher sidecar faithfulness endpoint.
DEEP_AGENT_FAITHFULNESS_URL=http://localhost:8001/faithfulness_check

# ── Deep Tree Mode (SPEC-DEEP-003) ──────────────────────────────────────────
# Tree-mode BFS expansion for multi-agent /deep exploration.
# Disabled by default; set DEEP_TREE_ENABLED=true to activate.

# Enable tree-mode expansion (default: false).
DEEP_TREE_ENABLED=false
# Default number of child nodes per expansion (1-8, default: 4).
DEEP_TREE_DEFAULT_BREADTH=4
# Maximum tree depth (1-5, default: 3).
DEEP_TREE_DEFAULT_DEPTH=3
# Maximum total tokens for the entire tree expansion (default: 60000).
DEEP_TREE_TOKEN_BUDGET=60000
# Seed token estimate for root node expansion (default: 5000).
DEEP_TREE_ROOT_TOKEN_ESTIMATE=5000
# Per-node timeout in milliseconds (default: 30000).
DEEP_TREE_NODE_TIMEOUT_MS=30000
# LiteLLM model alias for the decompose call (default: claude-3-5-haiku-20241022).
DEEP_TREE_DECOMPOSE_MODEL=claude-3-5-haiku-20241022
# Directory for tree.json persistence (default: .moai/runs).
DEEP_TREE_PERSISTENCE_DIR=.moai/runs
