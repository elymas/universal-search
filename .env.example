# Universal Search — root environment template
# Copy to .env: cp .env.example .env
# Fill in values before running make compose-up.
# This file is committed; .env is gitignored.
#
# Every ${VAR} referenced in deploy/docker-compose.yml must appear here.

# ── Meilisearch ────────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=change_me_meilisearch_key
MEILI_ENV=development

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=usearch
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=usearch
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=change_me_litellm_key
# Full DSN used by LiteLLM for its own database storage
DATABASE_URL=postgresql://usearch:change_me_postgres_password@postgres:5432/usearch
# Redis DSN used by LiteLLM for caching
REDIS_URL=redis://redis:6379/0

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ── SearXNG ────────────────────────────────────────────────────────────────────
SEARXNG_PORT=8080
SEARXNG_BASE_URL=http://localhost:8080/
SEARXNG_SECRET=change_me_searxng_secret

# ── LiteLLM provider API keys (optional; blank means provider disabled) ────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── LiteLLM budget cap per request (USD; 0 = unlimited) ───────────────────────
# SPEC-LLM-001 NFR-LLM-003: enforced post-flight by both proxy and client.
LITELLM_BUDGET_USD=0.50

# ── Ollama local inference base URL ───────────────────────────────────────────
# Leave default for Docker Desktop (macOS/Windows). Linux: http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── LiteLLM proxy port ─────────────────────────────────────────────────────────
LITELLM_PORT=4000

# ── Observability (REQ-OBS-001..REQ-OBS-005) ───────────────────────────────────
# Structured log level: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=info

# usearch admin server port for /metrics and /healthz (localhost-only)
# Leave blank to disable the admin server.
USEARCH_ADMIN_PORT=9090

# OpenTelemetry OTLP gRPC exporter endpoint (e.g. "localhost:4317").
# Leave blank to install a no-op tracer (zero overhead).
OTLP_ENDPOINT=

# Trace sampling ratio [0.0, 1.0]. Default 0.1 (10%).
OTLP_SAMPLE_RATIO=0.1

# Loki push endpoint (REQ-OBS-007, Phase 2 — reserved, not yet active).
LOKI_ENDPOINT=

# Prometheus UI port exposed by the prometheus container in docker-compose.
PROMETHEUS_PORT=9091

# Prometheus scrape port — must match USEARCH_ADMIN_PORT so Prometheus can
# reach the usearch /metrics endpoint from inside Docker.
PROMETHEUS_SCRAPE_PORT=9090

# ── Researcher synthesis sidecar (SPEC-SYN-001) ────────────────────────────────
# Base URL for the Go-side synthesis client to reach the sidecar.
RESEARCHER_BASE_URL=http://localhost:8081
# Per-request timeout in seconds for the Go-side synthesis HTTP client (default 10).
RESEARCHER_REQUEST_TIMEOUT_SECONDS=10
# Port the Python sidecar listens on inside Docker.
RESEARCHER_PORT=8081
# Default LLM model alias used by the sidecar (must be declared in deploy/litellm/config.yaml).
RESEARCHER_MODEL_DEFAULT=claude-haiku-4-5
# Synthesis wall-clock timeout in seconds for the Python sidecar LLM call.
RESEARCHER_TIMEOUT_SECONDS=8

# ── BGE-M3 embedding sidecar (SPEC-IDX-002) ────────────────────────────────────
# Base URL for the Go-side embedder client to reach the sidecar.
EMBEDDER_BASE_URL=http://localhost:8082
# Per-request timeout in seconds for the Go-side embedder HTTP client (default 15).
EMBEDDER_REQUEST_TIMEOUT_SECONDS=15
# Port the Python sidecar listens on inside Docker.
EMBEDDER_PORT=8082
# HuggingFace model ID for the embedding sidecar (default BAAI/bge-m3).
EMBEDDER_MODEL_NAME=BAAI/bge-m3
# Inference device: cpu | cuda (default cpu; override in docker-compose.gpu.yml).
EMBEDDER_DEVICE=cpu
# Use FP16 precision for GPU inference (default false; set true with EMBEDDER_DEVICE=cuda).
EMBEDDER_USE_FP16=false
# In-process LRU cache size in entries. Set 0 to disable the cache.
EMBEDDER_CACHE_MAX_ENTRIES=1024
# Log level for the Python sidecar: DEBUG | INFO | WARNING | ERROR (default INFO).
EMBEDDER_LOG_LEVEL=INFO
