root = true

# Universal Search — EditorConfig (REQ-BOOT-009)
# https://editorconfig.org

[*]
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# Go: tabs, width 4
[*.go]
indent_style = tab
indent_size = 4

# Python: spaces, width 4
[*.py]
indent_style = space
indent_size = 4

# TypeScript / JavaScript: spaces, width 2
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2

# YAML: spaces, width 2
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown: spaces, width 2
[*.md]
indent_style = space
indent_size = 2

# JSON: spaces, width 2
[*.json]
indent_style = space
indent_size = 2

# TOML: spaces, width 2
[*.toml]
indent_style = space
indent_size = 2

# Shell: spaces, width 2
[*.sh]
indent_style = space
indent_size = 2
