# YouTube extraction sidecar environment variables
# Copy to .env and fill in values before running

# Port the sidecar listens on (default: 8084)
YT_EXTRACT_PORT=8084

# Log level for the sidecar: DEBUG | INFO | WARNING | ERROR (default INFO)
YT_EXTRACT_LOG_LEVEL=INFO

# Optional: path to yt-dlp cookies file for IP-block mitigation.
# Leave blank for the public no-auth path.
YT_COOKIES_PATH=

# Optional: override User-Agent header sent by yt-dlp.
YT_USER_AGENT=

# Rate-limiting sleep flags (seconds). These are passed to yt-dlp subprocess.
# Defaults per ADP-005 D4.
YT_SLEEP_REQUESTS=1.0
YT_SLEEP_INTERVAL=2
YT_MAX_SLEEP_INTERVAL=5
