# Researcher service environment variables
# Copy to .env and fill in values before running

# OpenAI-compatible LLM API key (routed via LiteLLM proxy)
OPENAI_API_KEY=

# Tavily search API key (used by gpt-researcher)
TAVILY_API_KEY=

# Override LiteLLM proxy base URL if not using localhost:4000
OPENAI_BASE_URL=http://localhost:4000/v1

# Log level for the researcher service
RESEARCHER_LOG_LEVEL=INFO
