# Storm service environment variables
# Copy to .env and fill in values before running

# ---- LiteLLM proxy (in-container env) ----
# Base URL for LiteLLM proxy (matches services/researcher/src/researcher/gateway.py:26).
# Default points at LiteLLM container in docker-compose network;
# override to http://localhost:4000 when running outside compose network.
LITELLM_BASE_URL=http://litellm:4000

# In-container API key for LiteLLM (matches researcher gateway.py:27).
# The host-side LITELLM_MASTER_KEY is aliased into the container's
# LITELLM_API_KEY by deploy/docker-compose.yml (per researcher precedent).
# Never log this value.
LITELLM_API_KEY=

# ---- STORM configuration (spec.md §2.1(g)) ----

# Per-call latency ceiling in milliseconds (default: 300000 = 5 min)
STORM_MAX_LATENCY_MS=300000

# Per-call cost budget in USD (default: 2.50)
STORM_MAX_COST_USD=2.50

# Number of perspectives STORM explores (conservative; STORM default is 3)
STORM_MAX_PERSPECTIVES=2

# Max conversation turns per perspective (conservative)
STORM_MAX_CONV_TURNS=2

# Search top-k results per query
STORM_SEARCH_TOP_K=3

# Max parallel threads for STORM
STORM_MAX_THREAD_NUM=3

# Enable article polishing step (default off; enable empirically)
STORM_DO_POLISH=false

# Faithfulness mode: strip (default) | reject | off
STORM_FAITHFULNESS_MODE=strip

# Model for outline generation
STORM_MODEL_OUTLINE=claude-haiku-4-5

# Model for article generation
STORM_MODEL_ARTICLE=claude-sonnet-4-6

# Storm service port (default: 8001)
STORM_PORT=8001

# ---- Observability ----
# Log level for the storm service (JSON-formatted output)
STORM_LOG_LEVEL=INFO
