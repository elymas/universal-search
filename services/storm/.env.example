# Storm service environment variables
# Copy to .env and fill in values before running

# LiteLLM proxy base URL (matches services/researcher/src/researcher/gateway.py:26).
# Default value points at the LiteLLM container in the docker-compose network;
# override to http://localhost:4000 when running outside the compose network.
LITELLM_BASE_URL=http://litellm:4000

# LiteLLM master key for Bearer authentication (per SPEC-LLM-001 REQ-LLM-005).
# Single shared key across all services; never log this value.
LITELLM_MASTER_KEY=

# Log level for the storm service
STORM_LOG_LEVEL=INFO
