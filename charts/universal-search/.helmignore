# Patterns to ignore when building Helm packages.
.DS_Store
.git/
.gitignore
*.tmproj
.vscode/
.idea/
*.bak
*.tmp
*.orig
*.swp
# CI overlay values are documentation/test artifacts, not packaged defaults —
# but we keep ci/ in the package so operators can reference the examples.
# (Intentionally NOT ignoring ci/.)
